# ============================================================
# Async Execution System — Environment Configuration
# ============================================================
# Copy this file to .env and customize for your environment.

# ---- Application ----
APP_NAME=API Security Testing Platform
APP_VERSION=1.0.0
DEBUG=false

# ---- Database ----
# Default: PostgreSQL (production). Point this at your real database host.
# IMPORTANT: when the backend is deployed separately from the database
# (Render/Railway/EC2/managed Postgres), DATABASE_URL must reference the REAL
# DB host. "localhost" inside a deployed container refers to the container
# itself and cannot reach an external database.
DATABASE_URL= database_url


# Local dev alternative: SQLite (no external dependencies). Uncomment to use,
# or simply run ./start-fullstack.sh which forces SQLite automatically.
# DATABASE_URL=sqlite+aiosqlite:///./test.db

# ---- Redis ----
# If Redis is not available, the system auto-falls back to in-memory FakeRedis.
# In production set REDIS_URL to the real Redis host (not localhost).
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_URL=redis://redis-host:6379/0

# ---- CORS ----
# Comma-separated list of allowed frontend origins. "*" is for development only.
# In production list every frontend domain explicitly, e.g.:
# CORS_ORIGINS=https://integrated-work.vercel.app,https://www.example.com
CORS_ORIGINS=https://trustlayerapi.netlify.app/
# Extra regex (applied alongside CORS_ORIGINS) so preview deploys work:
# CORS_ORIGIN_REGEX=https://.*\.(netlify\.app|vercel\.app)|http://localhost:\d+

# ---- Worker Configuration ----
WORKER_CONCURRENCY=100
WORKER_HEARTBEAT_INTERVAL=5
WORKER_TIMEOUT=30

# ---- Rate Limiting & Retry ----
DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_BACKOFF=2.0

# ---- HTTP hardening (middleware) ----
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
REQUEST_TIMEOUT_SECONDS=30
REQUEST_LOGGING_ENABLED=true
SECURITY_HEADERS_ENABLED=true
# Enable only when always served over HTTPS:
ENABLE_HSTS=false

# ---- Authentication (JWT) ----
# Set a strong random secret in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=openssl rand -hex 32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set true to require a valid token on protected business endpoints:
AUTH_REQUIRED=true
# Optional: auto-create an admin on first startup
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# ---- Frontend ----
NEXT_PUBLIC_API_URL=https://trustlayerapi.netlify.app/
